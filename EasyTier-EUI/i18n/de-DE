[manifest]
display_name="EasyTier-EUI"
desc="Vereinfachte UI für EasyTier, senkt die Einstiegshürde für Netzwerke und ermöglicht schnellen Zugriff auf entfernte Netzwerkgeräte</br>Nutzen Sie EasyTier Vorteile: kostenlos, unbegrenzte Geräte, Multi-Plattform-Unterstützung und mehr</br>Damit andere Geräte dem Netzwerk beitreten können, gehen Sie zum [Apps]-Menü, laden Sie die App für das entsprechende System/die Architektur herunter und folgen Sie den Anweisungen zum Beitritt</br>Weitere EasyTier-Tipps finden Sie in der <a href="https://easytier.cn" target="_blank">offiziellen Dokumentation</a></br></br><a href="/cgi/ThirdParty/EasyTier-EUI/index.cgi/index.html" target="_blank">EasyTier-EUI Web-UI Schnellzugriff</a></br>"

[install]
stepTitle="Willkommen zur Installation"
tips1.helpText="Willkommen zur Installation von EasyTier-EUI, einer praktischen UI für EasyTier"
tips2.helpText="EasyTier benötigt Administratorrechte zum Erstellen eines TUN-Geräts für virtuelles Networking. Sie müssen EasyTier-EUI die Ausführung mit Root-Rechten erlauben"
wizard_agree_terms.label="Ich habe die Autorisierung gelesen und stimme zu"
wizard_agree_terms.rules1.message="Bitte stimmen Sie der Autorisierung zu"

[uninstall]
stepTitle="Deinstallation bestätigen"
tips1.helpText="Sie sind dabei, diese App zu deinstallieren. Bitte wählen Sie, wie mit den App-Daten verfahren werden soll"
wizard_data_action.label="Datenaufbewahrungsoption"
wizard_data_action.options1.label="Daten behalten (Empfohlen) - Bei Neuinstallation wiederherstellbar"
wizard_data_action.options2.label="Alle Daten löschen - Diese Aktion kann nicht rückgängig gemacht werden"
wizard_data_action.rules1.message="Bitte wählen Sie eine Datenaufbewahrungsoption"
tips2.helpText="<strong>Warnung:</strong> Nach dem Löschen der Daten gehen alle App-Daten dauerhaft verloren und können nicht wiederhergestellt werden."